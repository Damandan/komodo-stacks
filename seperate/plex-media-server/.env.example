# Hostname to expose from inside the Plex container.
# Example: media-host
PLEX_HOSTNAME=<plex_container_hostname>
# Linux host path for Plex database/config data.
# Example: /srv/docker-data/plex/database
PLEX_CONFIG_PATH=<linux_path_to_plex_config>
# Linux host path for additional Plex multimedia assets.
# Example: /srv/docker-data/plex/multimedia
PLEX_MULTIMEDIA_PATH=<linux_path_to_plex_multimedia>
# Linux host path to XML EPG file mounted into Plex.
# Example: /srv/docker-data/epg/guide.xml
PLEX_EPG_FILE_PATH=<linux_path_to_epg_xml_file>
# Linux host path for Plex transcoding temp data.
# Example: /srv/docker-data/plex/transcode
PLEX_TRANSCODE_PATH=<linux_path_to_plex_transcode>
# Linux host path for series library.
# Example: /srv/media/series
SERIES_PATH=<linux_path_to_series_library>
# Linux host path for primary movies library.
# Example: /srv/media/movies
MOVIES_PATH=<linux_path_to_movies_library>
# Linux host path for secondary movies library.
# Example: /srv/media/movies-4k
MOVIES_2_PATH=<linux_path_to_secondary_movies_library>
# Linux host path for music library.
# Example: /srv/media/music
MUSIC_PATH=<linux_path_to_music_library>
# Plex claim token (short-lived token from plex.tv/claim).
# Example: claim-xxxxxxxxxxxxxxxx
PLEX_CLAIM=<plex_claim_token>
# Comma-separated advertise URLs for Plex.
# Example: http://plex.local,http://192.168.1.50:32400
ADVERTISE_IP=<comma_separated_advertise_urls>
