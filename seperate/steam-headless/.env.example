# Linux host DBus socket path.
# Example: /run/dbus
DBUS_PATH=<linux_path_to_dbus_socket>
# Linux fuse device path.
# Example: /dev/fuse
FUSE_DEVICE_PATH=<linux_path_to_fuse_device>
# Linux uinput device path.
# Example: /dev/uinput
UINPUT_DEVICE_PATH=<linux_path_to_uinput_device>
# Hostname used by the Steam headless container.
# Example: SteamHeadless
STEAM_HOSTNAME=<steam_container_hostname>
# Timezone for container processes.
# Example: Europe/Amsterdam
TZ=<timezone_region_city>
# Locale definitions expected by the image.
# Example: en_US.UTF-8 UTF-8
USER_LOCALES=<locale_definition>
# X display number used by the container.
# Example: :55
DISPLAY=<x_display>
# Shared memory size for the container.
# Example: 8G
SHM_SIZE=<shared_memory_size>
# Linux host path for persistent home directory.
# Example: /srv/docker-data/steam-headless/home
HOME_DIR=<linux_path_to_steam_home>
# Linux host path for shared sockets directory.
# Example: /srv/docker-data/steam-headless/sockets
SHARED_SOCKETS_DIR=<linux_path_to_shared_sockets>
# Linux host path for installed games library.
# Example: /srv/docker-data/steam-headless/games
GAMES_DIR=<linux_path_to_games_library>
# UID used inside container.
# Example: 1000
PUID=<linux_uid>
# GID used inside container.
# Example: 1000
PGID=<linux_gid>
# File mode creation mask.
# Example: 022
UMASK=<umask_value>
# Password for the default user in the container.
# Example: generate a long random password
USER_PASSWORD=<steam_user_password>
# Container operation mode.
# Example: primary
MODE=<steam_mode>
# Web UI mode.
# Example: vnc
WEB_UI_MODE=<web_ui_mode>
# Enable or disable VNC audio.
# Example: false
ENABLE_VNC_AUDIO=<true_or_false>
# noVNC web port.
# Example: 8083
PORT_NOVNC_WEB=<novnc_port>
# Optional public NAT IP for Neko.
# Example: 203.0.113.10
NEKO_NAT1TO1=<public_nat_ip_or_empty>
# Enable Steam startup.
# Example: true
ENABLE_STEAM=<true_or_false>
# Additional Steam launch arguments.
# Example: -silent
STEAM_ARGS=<steam_args_or_empty>
# Enable Sunshine game streaming.
# Example: false
ENABLE_SUNSHINE=<true_or_false>
# Sunshine web username.
# Example: sunshine_admin
SUNSHINE_USER=<sunshine_username>
# Sunshine web password.
# Example: generate a strong random password
SUNSHINE_PASS=<sunshine_password>
# Enable evdev device inputs.
# Example: true
ENABLE_EVDEV_INPUTS=<true_or_false>
# Force generation of X11 dummy config.
# Example: true
FORCE_X11_DUMMY_CONFIG=<true_or_false>
# NVIDIA driver capabilities list.
# Example: all
NVIDIA_DRIVER_CAPABILITIES=<nvidia_driver_capabilities>
# GPU selection for NVIDIA runtime.
# Example: all
NVIDIA_VISIBLE_DEVICES=<nvidia_visible_devices>
# Optional fixed NVIDIA driver version.
# Example: 550.90.07
NVIDIA_DRIVER_VERSION=<nvidia_driver_version_or_empty>
# Whether to use host DBus integration.
# Example: true
HOST_DBUS=<true_or_false>
