# Linux host path for localtime passthrough.
# Example: /etc/localtime
LOCALTIME_PATH=<linux_path_to_localtime>
# Linux host DBus socket path.
# Example: /run/dbus
DBUS_PATH=<linux_path_to_dbus_socket>
# Linux host path for Home Assistant config data.
# Example: /srv/docker-data/homeassistant
HOMEASSISTANT_CONFIG_PATH=<linux_path_to_homeassistant_config>
# Linux host path for Matter server data.
# Example: /srv/docker-data/matter-server/data
MATTER_SERVER_DATA_PATH=<linux_path_to_matter_data>
# Linux host path to modbus-proxy configuration file.
# Example: /srv/stacks/home/modbus-proxy.yml
MODBUS_PROXY_CONFIG_PATH=<linux_path_to_modbus_proxy_yml>
# Linux host path for MariaDB database files.
# Example: /srv/docker-data/mariadb/data
MARIADB_DATA_PATH=<linux_path_to_mariadb_data>
# Linux host path to custom MariaDB config file.
# Example: /srv/docker-data/mariadb/my.cnf
MARIADB_CUSTOM_CNF_PATH=<linux_path_to_mariadb_custom_cnf>
# Linux host path for Spotweb config data.
# Example: /srv/docker-data/spotweb/config
SPOTWEB_CONFIG_PATH=<linux_path_to_spotweb_config>
# MariaDB root password.
# Example: generate a strong random secret
MARIADB_ROOT_PASSWORD=<mariadb_root_password>
# Spotweb database host/IP reachable by Spotweb.
# Example: 192.168.1.10
SPOTWEB_DB_HOST=<spotweb_db_host>
# Spotweb database port.
# Example: 3306
SPOTWEB_DB_PORT=<spotweb_db_port>
# Spotweb database name.
# Example: spotweb
SPOTWEB_DB_NAME=<spotweb_db_name>
# Spotweb database username.
# Example: spotweb_user
SPOTWEB_DB_USER=<spotweb_db_user>
# Spotweb database password.
# Example: generate a strong random secret
SPOTWEB_DB_PASS=<spotweb_db_password>
