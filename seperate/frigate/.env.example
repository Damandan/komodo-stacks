# Linux host path for localtime passthrough.
# Example: /etc/localtime
LOCALTIME_PATH=<linux_path_to_localtime>
# Linux host USB bus device path for camera hardware.
# Example: /dev/bus/usb
USB_BUS_PATH=<linux_path_to_usb_bus>
# Linux host path for Frigate config directory.
# Example: /srv/docker-data/frigate/config
FRIGATE_CONFIG_PATH=<linux_path_to_frigate_config>
# Linux host path where Frigate stores recordings/media.
# Example: /srv/media/nvr
FRIGATE_MEDIA_PATH=<linux_path_to_frigate_media>
# MQTT username for Frigate.
# Example: frigate_mqtt_user
FRIGATE_MQTT_USER=<mqtt_username>
# MQTT password for Frigate.
# Example: generate a long random password
FRIGATE_MQTT_PASSWORD=<mqtt_password>
