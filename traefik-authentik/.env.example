# PostgreSQL database name for Authentik.
# Example: authentik
POSTGRES_DB=<postgres_database_name>
# PostgreSQL user for Authentik.
# Example: authentik_user
POSTGRES_USER=<postgres_username>
# TransIP account name used by Traefik DNS challenge.
# Example: your_transip_account
TRANSIP_ACCOUNT_NAME=<transip_account_name>
# Path inside container to TransIP private key file.
# Example: /transip/transip.key
TRANSIP_PRIVATE_KEY_PATH=<container_path_to_transip_key>
# Linux host path for Docker socket.
# Example: /var/run/docker.sock
DOCKER_SOCKET_PATH=<linux_path_to_docker_socket>
# Linux host path to Traefik static config file.
# Example: /srv/docker-data/traefik/traefik.yaml
TRAEFIK_STATIC_CONFIG_PATH=<linux_path_to_traefik_yaml>
# Linux host path to Traefik dynamic config file.
# Example: /srv/docker-data/traefik/dynamic.yaml
TRAEFIK_DYNAMIC_CONFIG_PATH=<linux_path_to_dynamic_yaml>
# Linux host path to Traefik ACME JSON file.
# Example: /srv/docker-data/traefik/certificates/acme.json
TRAEFIK_ACME_PATH=<linux_path_to_acme_json>
# Optional Linux host path to fullchain certificate file.
# Example: /srv/docker-data/traefik/certificates/fullchain.pem
TRAEFIK_FULLCHAIN_PATH=<linux_path_to_fullchain_pem>
# Optional Linux host path to private key certificate file.
# Example: /srv/docker-data/traefik/certificates/privkey.pem
TRAEFIK_PRIVKEY_PATH=<linux_path_to_privkey_pem>
# Linux host path mounted for TransIP files.
# Example: /srv/docker-data/traefik/transip
TRAEFIK_TRANSIP_PATH=<linux_path_to_traefik_transip_dir>
# Linux host path for PostgreSQL data.
# Example: /srv/docker-data/postgresql/database
POSTGRES_DATA_PATH=<linux_path_to_postgres_data>
# Linux host path for Authentik custom templates.
# Example: /srv/docker-data/authentik/custom-templates
AUTHENTIK_TEMPLATES_PATH=<linux_path_to_authentik_templates>
# Linux host path for Authentik media storage.
# Example: /srv/docker-data/authentik/media
AUTHENTIK_MEDIA_PATH=<linux_path_to_authentik_media>
# Linux host path for Authentik cert storage.
# Example: /srv/docker-data/authentik/certs
AUTHENTIK_CERTS_PATH=<linux_path_to_authentik_certs>
# PostgreSQL password for the configured user.
# Example: generate a strong random password
POSTGRES_PASSWORD=<postgres_password>
# Authentik secret key.
# Example: generate a long random string
AUTHENTIK_SECRET_KEY=<authentik_secret_key>
# Enable Authentik anonymous error reporting.
# Example: true
AUTHENTIK_ERROR_REPORTING__ENABLED=<true_or_false>
# SMTP host for outbound email.
# Example: smtp.example.com
AUTHENTIK_EMAIL__HOST=<smtp_host>
# SMTP port.
# Example: 465
AUTHENTIK_EMAIL__PORT=<smtp_port>
# SMTP username/login.
# Example: noreply@example.com
AUTHENTIK_EMAIL__USERNAME=<smtp_username>
# SMTP password or app-specific password.
# Example: generate/store securely
AUTHENTIK_EMAIL__PASSWORD=<smtp_password>
# Enable STARTTLS for SMTP.
# Example: true
AUTHENTIK_EMAIL__USE_TLS=<true_or_false>
# Enable implicit SSL for SMTP.
# Example: true
AUTHENTIK_EMAIL__USE_SSL=<true_or_false>
# SMTP timeout in seconds.
# Example: 10
AUTHENTIK_EMAIL__TIMEOUT=<smtp_timeout_seconds>
# Enable stack traces in Authentik logs/errors.
# Example: false
AUTHENTIK_ENABLE_STACKTRACES=<true_or_false>
# OpenTelemetry endpoint.
# Example: http://otel-collector:4318
OTEL_EXPORTER_OTLP_ENDPOINT=<otel_http_endpoint>
# Trace exporter type.
# Example: otlp
OTEL_TRACES_EXPORTER=<otel_traces_exporter>
# Metrics exporter type.
# Example: none
OTEL_METRICS_EXPORTER=<otel_metrics_exporter>
